# Copy to .env and adjust as needed.

# App settings use the APP_ prefix.
APP_APP_NAME="Personal Sensei API"
APP_VERSION="0.1.0"
APP_ENVIRONMENT="development"

# Agent / model settings (APP_ prefix).
APP_OPENAI_MODEL="gpt-4o-mini"
APP_AGENT_TEMPERATURE="0.0"
APP_AGENT_MAX_TOKENS="1024"

# Comma-separated CORS origins (APP_ prefix). JSON list also accepted.
APP_CORS_ALLOW_ORIGINS='["http://localhost:3000"]'

# OpenAI credentials — read directly by langchain (no APP_ prefix).
OPENAI_API_KEY="sk-..."
